<Window x:Class="StarBridge.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StarBridge.Desktop"
        Title="Star Bridge"
        Icon="/Assets/Brand/StarBridge_AppIcon.ico"
        Width="1664"
        Height="988"
        MinWidth="1404"
        MinHeight="884"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="MainWindow_Closing"
        StateChanged="MainWindow_StateChanged">
    <Window.Resources>
        <local:ImagePathConverter x:Key="ImagePathConverter" />
        <local:ImageDataConverter x:Key="ImageDataConverter" />
    </Window.Resources>
    <Border Background="{StaticResource PageBackgroundBrush}"
            BorderBrush="{StaticResource AccentDimBrush}"
            BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Rectangle Fill="{StaticResource VerticalStreakBrush}"
                   Grid.RowSpan="2"
                   IsHitTestVisible="False" />
        <Rectangle Fill="{StaticResource ScanlineBrush}"
                   Grid.RowSpan="2"
                   IsHitTestVisible="False" />
        <Rectangle Fill="{StaticResource GeometricBackgroundBrush}"
                   Grid.RowSpan="2"
                   IsHitTestVisible="False" />
        <Border VerticalAlignment="Top"
                Height="2"
                Grid.RowSpan="2"
                Background="{StaticResource AccentDimBrush}"
                Opacity="0.62"
                IsHitTestVisible="False" />

        <Border x:Name="CustomTitleBar"
                Grid.Row="0"
                Background="#F0162634"
                MouseLeftButtonDown="CustomTitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="48" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0">
                    <TextBlock x:Name="WindowTitleText"
                               Text="星海舰桥 V0.3.12"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="&#xE921;"
                        Style="{StaticResource WindowCaptionButton}"
                        Click="MinimizeWindowButton_Click" />
                <Button Grid.Column="2"
                        x:Name="MaximizeWindowButton"
                        Content="&#xE922;"
                        Style="{StaticResource WindowCaptionButton}"
                        Click="MaximizeWindowButton_Click" />
                <Button Grid.Column="3"
                        Content="&#xE8BB;"
                        Style="{StaticResource CloseWindowCaptionButton}"
                        Click="CloseWindowButton_Click" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="88" />
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="365" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    BorderThickness="0"
                    Background="Transparent"
                    Cursor="Hand"
                    MouseLeftButtonUp="BrandLogo_MouseLeftButtonUp">
                <Image Source="/Assets/Brand/StarBridge_logo.png"
                       Stretch="Uniform"
                       Width="360"
                       Height="70"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"
                       Margin="0" />
            </Border>

            <Button Grid.Column="1"
                    x:Name="FindFleetNavButton"
                    Style="{StaticResource NavButton}"
                    Click="FindFleetNav_Click">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="64"
                            Height="64"
                            VerticalAlignment="Center"
                            CornerRadius="8"
                            BorderBrush="#6638BFFF"
                            BorderThickness="1"
                            Background="#22070D14">
                        <Image Source="/Assets/Navigation/SearchFleet_Nav.png"
                               Width="60"
                               Height="60"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <TextBlock x:Name="FindFleetNavText"
                                   Text="Find Fleet"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button Grid.Column="2"
                    x:Name="MyFleetNavButton"
                    Style="{StaticResource NavButton}"
                    Click="MyFleetNav_Click">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="64"
                            Height="64"
                            VerticalAlignment="Center"
                            CornerRadius="8"
                            BorderBrush="#6638BFFF"
                            BorderThickness="1"
                            Background="#22070D14">
                        <Image Source="/Assets/Navigation/MyFleet_Nav.png"
                               Width="60"
                               Height="60"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <TextBlock x:Name="MyFleetNavText"
                                   Text="My Fleet"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button Grid.Column="3"
                    x:Name="MySquadNavButton"
                    Style="{StaticResource NavButton}"
                    Click="MySquadNav_Click">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="64"
                            Height="64"
                            VerticalAlignment="Center"
                            CornerRadius="8"
                            BorderBrush="#6638BFFF"
                            BorderThickness="1"
                            Background="#22070D14">
                        <Image Source="/Assets/Navigation/MySquad_Nav.png"
                               Width="60"
                               Height="60"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <TextBlock x:Name="MySquadNavText"
                                   Text="My Squad"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button Grid.Column="4"
                    x:Name="OverlayNavButton"
                    Style="{StaticResource NavButton}"
                    Click="OverlayNav_Click">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="64"
                            Height="64"
                            VerticalAlignment="Center"
                            CornerRadius="8"
                            BorderBrush="#6638BFFF"
                            BorderThickness="1"
                            Background="#22070D14">
                        <Image Source="/Assets/Navigation/Overlay_Nav.png"
                               Width="60"
                               Height="60"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <TextBlock x:Name="OverlayNavText"
                                   Text="Overlay"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button Grid.Column="5"
                    x:Name="PersonalNavButton"
                    Style="{StaticResource NavButton}"
                    Margin="0"
                    Click="PersonalNav_Click">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="64"
                            Height="64"
                            VerticalAlignment="Center"
                            CornerRadius="8"
                            BorderBrush="#6638BFFF"
                            BorderThickness="1"
                            Background="#22070D14">
                        <Image Source="/Assets/Navigation/Personal_Nav.png"
                               Width="60"
                               Height="60"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <TextBlock x:Name="PersonalNavText"
                                   Text="Personal"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="138" />
                <ColumnDefinition Width="126" />
                <ColumnDefinition Width="0" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Star Bridge"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />

            <TextBox Grid.Row="0"
                     Grid.Column="0"
                     x:Name="LogPathBox"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Text="No Game.log selected" />

            <Button Grid.Row="0"
                    Grid.Column="1"
                    x:Name="SelectLogButton"
                    Margin="12,0,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Content="Select Log"
                    Click="SelectLog_Click" />

            <ComboBox Grid.Row="0"
                      Grid.Column="3"
                      x:Name="LanguageBox"
                      Margin="12,0,0,0"
                      VerticalContentAlignment="Center"
                      Visibility="Collapsed"
                      SelectionChanged="LanguageBox_SelectionChanged">
                <ComboBoxItem Content="English" Tag="en" />
                <ComboBoxItem Content="中文" Tag="zh" />
            </ComboBox>

            <Button Grid.Row="0"
                    Grid.Column="3"
                    x:Name="NetworkTestNavButton"
                    Margin="12,0,0,0"
                    Style="{StaticResource SecondaryButton}"
                    Content="联网测试 / 监控"
                    ToolTip="打开联网测试与同步监控页面"
                    Visibility="Collapsed"
                    Click="NetworkTestNav_Click" />

            <Button Grid.Row="0"
                    Grid.Column="2"
                    x:Name="ToggleOverlayButton"
                    Margin="12,0,0,0"
                    Style="{StaticResource SecondaryButton}"
                    Content="Toggle Overlay"
                    Click="OpenOverlay_Click" />

            <Border Grid.Row="1"
                    Grid.ColumnSpan="4"
                    Margin="0,9,0,0"
                    Padding="12,7"
                    BorderBrush="{StaticResource AccentDimBrush}"
                    BorderThickness="1"
                    Background="#7007101B"
                    Visibility="Collapsed">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="运行状态"
                                   Style="{StaticResource HudCaptionText}"
                                   Margin="0,0,14,0" />

                        <Border BorderBrush="{StaticResource AccentDimBrush}"
                                BorderThickness="1"
                                Background="#660A1624"
                                Padding="9,3"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="账号"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,0,8,0" />
                                <TextBlock x:Name="HeaderAccountStatusText"
                                           Text="未登录"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{StaticResource AccentDimBrush}"
                                BorderThickness="1"
                                Background="#660A1624"
                                Padding="9,3"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="连接"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,0,8,0" />
                                <TextBlock x:Name="HeaderSyncStatusText"
                                           Text="未连接"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{StaticResource AccentDimBrush}"
                                BorderThickness="1"
                                Background="#660A1624"
                                Padding="9,3">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="游戏"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,0,8,0" />
                                <TextBlock x:Name="HeaderGameProcessStatusText"
                                           Text="未运行"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="服务器"
                                   Style="{StaticResource HudCaptionText}"
                                   Margin="0,0,10,0" />
                        <TextBlock x:Name="HeaderGameServerRegionText"
                                   Text="未知"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <TabControl x:Name="MainTabs"
                    Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent" />
                </ControlTemplate>
            </TabControl.Template>
            <TabItem x:Name="FindFleetTab" Header="Find Fleet">
                <Border Margin="0,14,0,0"
                        Style="{StaticResource HudPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="FindFleetTitleText"
                                           Text="寻找舰队"
                                           Style="{StaticResource SectionTitleText}" />
                                <TextBlock x:Name="FindFleetPlaceholderText"
                                           Text="搜索公开舰队，确认加入方式后即可进入同一舰队同步。已加入的舰队会显示为当前舰队。"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    x:Name="RefreshFleetDirectoryButton"
                                    Height="38"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="刷新舰队"
                                    Click="RefreshFleetDirectory_Click" />
                        </Grid>
                        <Grid Grid.Row="1"
                              Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FindFleetSearchBox"
                                     Height="38"
                                     VerticalContentAlignment="Center"
                                     TextChanged="FindFleetSearchBox_TextChanged" />
                            <TextBlock Text="搜索舰队全名 / 识别码"
                                       Margin="14,0,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=FindFleetSearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="1"
                                       x:Name="FindFleetSearchCountText"
                                       Text=""
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Grid Grid.Row="2"
                              Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Style="{StaticResource GuidanceCardPanel}">
                                <StackPanel>
                                    <TextBlock Text="01 / SEARCH"
                                               Style="{StaticResource SectionEyebrowText}" />
                                    <TextBlock Text="搜索舰队全名或识别码"
                                               Margin="0,6,0,0"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="先确认舰队、指挥官与加入规则。"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Style="{StaticResource GuidanceCardPanel}">
                                <StackPanel>
                                    <TextBlock Text="02 / JOIN"
                                               Style="{StaticResource SectionEyebrowText}" />
                                    <TextBlock Text="加入或提交申请"
                                               Margin="0,6,0,0"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="如果你已有舰队，系统会在切换前确认。"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Style="{StaticResource GuidanceCardPanel}"
                                    Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="03 / SYNC"
                                               Style="{StaticResource SectionEyebrowText}" />
                                    <TextBlock Text="同步成员与任务状态"
                                               Margin="0,6,0,0"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="加入后即可看到舰队、小队、任务与 Overlay 信息。"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ScrollViewer Grid.Row="3"
                                      Margin="0,22,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <TextBlock x:Name="FindFleetEmptyText"
                                           Text="暂无公开舰队。你可以创建舰队，或稍后刷新目录。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0,80,0,0"
                                           Visibility="Collapsed" />
                                <ItemsControl x:Name="FindFleetResults">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SquadBannerPanel}"
                                                    Padding="14"
                                                    Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="124" />
                                                        <ColumnDefinition Width="280" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="230" />
                                                        <ColumnDefinition Width="130" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="104"
                                                            Height="104"
                                                            BorderBrush="{StaticResource AccentBrush}"
                                                            BorderThickness="1"
                                                            Background="{StaticResource FieldBackBrush}">
                                                        <Grid>
                                                            <Image Source="{Binding LogoImageData, Converter={StaticResource ImageDataConverter}}"
                                                                   Stretch="UniformToFill"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                            <TextBlock Text="{Binding LogoText}"
                                                                       Visibility="{Binding LogoTextVisibility}"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                    </Border>

                                                <StackPanel Grid.Column="1"
                                                            Margin="14,0,18,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               FontSize="20"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding CodeLine}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,6,0,0" />
                                                    <TextBlock Text="{Binding CommanderLine}"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               Margin="0,10,0,0" />
                                                    <TextBlock Text="{Binding JoinPolicyLine}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               Margin="0,10,0,0" />
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        BorderBrush="{StaticResource AccentDimBrush}"
                                                        BorderThickness="1"
                                                        Background="{StaticResource FieldBackBrush}"
                                                        Padding="14"
                                                        Margin="0,0,18,0">
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap" />
                                                </Border>

                                                <StackPanel Grid.Column="3"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,14,0">
                                                    <TextBlock Text="{Binding TypeLine}"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               FontSize="16"
                                                               TextAlignment="Right" />
                                                    <TextBlock Text="{Binding ActiveTimeLine}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Margin="0,14,0,0"
                                                               TextAlignment="Right" />
                                                    <TextBlock Text="{Binding MembersLine}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               Margin="0,14,0,0"
                                                               TextAlignment="Right" />
                                                </StackPanel>

                                                    <Button Grid.Column="4"
                                                            Height="40"
                                                            VerticalAlignment="Center"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Content="{Binding JoinButtonText}"
                                                            IsEnabled="{Binding CanJoin}"
                                                            Tag="{Binding}"
                                                            Click="JoinNetworkFleet_Click" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>
            <TabItem x:Name="FleetTab" Header="Fleet">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="190" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Style="{StaticResource HudPanel}"
                                    Padding="18,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="560" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="118" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="104"
                                        Height="104"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource FieldBackBrush}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="FleetHeaderLogo_MouseLeftButtonUp">
                                    <Grid>
                                        <Image x:Name="FleetHeaderLogoImage" Stretch="UniformToFill" />
                                        <TextBlock x:Name="FleetHeaderLogoText"
                                                   Text="LOGO"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1"
                                      Margin="12,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="24" />
                                        <RowDefinition Height="24" />
                                        <RowDefinition Height="24" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="FleetHeaderNameText"
                                                   Text="Fleet Name"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
