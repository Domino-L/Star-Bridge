<Window x:Class="StarBridge.Desktop.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="星海舰桥引导"
        Width="980"
        Height="720"
        MinWidth="880"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    <Border BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="1"
            Background="{StaticResource PageBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
                <RowDefinition Height="72" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{StaticResource AccentDimBrush}"
                    BorderThickness="0,0,0,1"
                    Background="#152034">
                <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="24,0,0,0"
                                VerticalAlignment="Center">
                        <TextBlock Text="星海舰桥首次启动引导"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="按顺序完成账号、日志、舰队、小队与 Overlay，之后就能开始完整测试。"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="X"
                            FontSize="18"
                            Click="CloseButton_Click"
                            Style="{StaticResource SecondaryButton}" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24">
                <StackPanel>
                    <Border Style="{StaticResource HudPanel}"
                            Padding="20"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="01"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="AccountStateText"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="登录或注册"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="登录后才能同步舰队、小队、任务、头像、舰船数据库和成员状态。未登录时可以浏览，但不能真正参与舰队协同。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,24,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="登录 / 注册"
                                    Click="LoginButton_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="42"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource HudPanel}"
                            Padding="20"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="02"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="LogStateText"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="选择 Game.log"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="日志是玩家在线、飞船、地点和服务器状态的基础来源。建议选择 StarCitizen\LIVE\Game.log。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,24,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="选择日志"
                                    Click="SelectLogButton_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="42"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource HudPanel}"
                            Padding="20"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="03"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="FleetStateText"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="加入或创建舰队"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="普通成员可以先寻找舰队并申请加入。舰队创建者会进入指挥官流程，可设置公告、任务、计划、成员权限与舰船数据库。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,24,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <Button Content="寻找舰队"
                                        Click="FindFleetButton_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="38"
                                        Margin="0,0,0,8" />
                                <Button Content="创建舰队"
                                        Click="CreateFleetButton_Click"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="38" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource HudPanel}"
                            Padding="20"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="04"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="SquadStateText"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="进入我的小队"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="加入舰队后，可以创建或加入小队。小队是 Overlay 成员状态、任务分配和战术协同的主要单位。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,24,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="前往小队"
                                    Click="MySquadButton_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="42"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource HudPanel}"
                            Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="05"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="30"
                                           FontWeight="Bold" />
                                <TextBlock x:Name="OverlayStateText"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="配置 Overlay"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="Overlay 可以显示舰队公告、当前任务、小队列表与成员状态。你可以调整布局、预设、透明度、准星与船厂风格。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,24,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="配置 Overlay"
                                    Click="OverlayButton_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="42"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource AccentDimBrush}"
                    BorderThickness="0,1,0,0"
                    Background="#0B1422">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="CompleteAfterActionCheck"
                              Content="执行此操作后不再自动显示"
                              Foreground="{StaticResource MutedTextBrush}"
                              VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="稍后再说"
                            Click="SkipButton_Click"
                            Style="{StaticResource SecondaryButton}"
                            Width="140"
                            Height="40"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Content="完成引导"
                            Click="FinishButton_Click"
                            Style="{StaticResource PrimaryButton}"
                            Width="140"
                            Height="40"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
