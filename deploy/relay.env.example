ASPNETCORE_URLS=http://127.0.0.1:5058
STARBRIDGE_RELAY_DATA=/var/lib/starbridge/relay-state.json
STARBRIDGE_RELAY_KEY=YOUR_SECRET_RELAY_KEY

STARBRIDGE_SMTP_HOST=smtp.gmail.com
STARBRIDGE_SMTP_PORT=587
STARBRIDGE_SMTP_USER=scstarbridge.app@gmail.com
STARBRIDGE_SMTP_PASS=YOUR_SMTP_APP_PASSWORD
STARBRIDGE_SMTP_FROM=scstarbridge.app@gmail.com
STARBRIDGE_SMTP_SSL=true

STARBRIDGE_LATEST_VERSION=0.3.6
STARBRIDGE_DOWNLOAD_URL=https://example.com/StarBridge-0.3.6-win-x64-setup.exe
STARBRIDGE_PACKAGE_URL=https://example.com/StarBridge-0.3.6-win-x64-update.zip
STARBRIDGE_RELEASE_NOTES=Release notes shown to users.
STARBRIDGE_UPDATE_REQUIRED=false
