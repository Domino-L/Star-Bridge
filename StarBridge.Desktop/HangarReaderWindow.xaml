<Window x:Class="StarBridge.Desktop.HangarReaderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="官网机库读取器"
        Width="1320"
        Height="820"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="AddressBox"
                     Text="https://robertsspaceindustries.com/en/account/pledges"
                     VerticalContentAlignment="Center"
                     Margin="0,0,8,0" />
            <Button Grid.Column="1"
                    Content="打开"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="GoButton_Click" />
            <Button Grid.Column="2"
                    Content="读取当前页"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0"
                    Click="ReadCurrentPageButton_Click" />
            <Button Grid.Column="3"
                    Content="导入舰船库"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0"
                    Click="ImportButton_Click" />
            <Button Grid.Column="4"
                    Content="关闭"
                    Style="{StaticResource SecondaryButton}"
                    Click="CloseButton_Click" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{StaticResource AccentDimBrush}"
                    BorderThickness="1"
                    Background="#FF050B12">
                <wv2:WebView2 x:Name="HangarWebView"
                              Source="https://robertsspaceindustries.com/en/account/pledges" />
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource HudPanel}"
                    Margin="12,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="读取说明"
                                   Style="{StaticResource HudCaptionText}"
                                   FontSize="16" />
                        <TextBlock Text="请在左侧自行登录 RSI，并进入 My Hangar。每翻到一页后点击“读取当前页”。应用只读取页面上标记为 Ship 的条目，不保存账号密码。"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,12" />
                        <TextBlock x:Name="ReaderStatusText"
                                   Text="等待读取。"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PageShipCountText"
                                   Text="当前页：0"
                                   Style="{StaticResource HudCaptionText}" />
                        <TextBlock Grid.Column="1"
                                   x:Name="TotalShipCountText"
                                   Text="累计：0"
                                   Style="{StaticResource HudCaptionText}"
                                   HorizontalAlignment="Right" />
                    </Grid>

                    <ListView Grid.Row="2"
                              x:Name="DetectedShipsList"
                              Background="{StaticResource FieldBackBrush}"
                              BorderBrush="{StaticResource AccentDimBrush}"
                              BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="舰船" DisplayMemberBinding="{Binding DisplayName}" Width="170" />
                                <GridViewColumn Header="代码" DisplayMemberBinding="{Binding Code}" Width="150" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
