<Window x:Class="StarBridge.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录星海舰桥"
        Width="720"
        Height="760"
        MinWidth="720"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource PageBackgroundBrush}"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="1"
            Padding="36">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="星海舰桥"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}" />
            <TextBlock Grid.Row="1"
                       Margin="0,10,0,18"
                       Text="登录后可同步舰队、小队、任务与玩家状态。你也可以先跳过，以浏览模式进入应用。"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" />

            <Grid Grid.Row="2" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="LoginModeButton"
                        Grid.Column="0"
                        Margin="0,0,8,0"
                        Content="登录"
                        Style="{StaticResource PrimaryButton}"
                        Click="LoginModeButton_Click" />
                <Button x:Name="RegisterModeButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="注册"
                        Style="{StaticResource SecondaryButton}"
                        Click="RegisterModeButton_Click" />
            </Grid>

            <Grid Grid.Row="3">
                <Grid x:Name="LoginPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="登录邮箱"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox x:Name="LoginEmailBox"
                             Grid.Row="0"
                             Height="38"
                             Margin="0,24,0,14"
                             VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Text="密码"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <PasswordBox x:Name="LoginPasswordBox"
                                 Grid.Row="1"
                                 Height="38"
                                 Margin="0,24,0,14"
                                 VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2"
                               Text="使用注册邮箱和密码登录，登录后将自动连接星海舰桥服务器。"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </Grid>

                <Grid x:Name="RegisterPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="登录邮箱"
                               Grid.ColumnSpan="2"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox x:Name="RegisterEmailBox"
                             Grid.ColumnSpan="2"
                             Height="38"
                             Margin="0,24,0,14"
                             VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="密码"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <PasswordBox x:Name="RegisterPasswordBox"
                                 Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Height="38"
                                 Margin="0,24,0,14"
                                 VerticalContentAlignment="Center" />

                    <TextBlock Grid.Row="2"
                               Grid.ColumnSpan="2"
                               Text="呼号（昵称）"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox x:Name="RegisterCallsignBox"
                             Grid.Row="2"
                             Grid.ColumnSpan="2"
                             Height="38"
                             Margin="0,24,0,14"
                             VerticalContentAlignment="Center"
                             MaxLength="24" />

                    <TextBlock Grid.Row="3"
                               Text="验证码"
                               Grid.ColumnSpan="2"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBox x:Name="VerificationCodeBox"
                             Grid.Row="3"
                             Height="38"
                             Margin="0,24,12,14"
                             VerticalContentAlignment="Center"
                             MaxLength="6" />
                    <Button x:Name="SendCodeButton"
                            Grid.Row="3"
                            Grid.Column="1"
                            Height="38"
                            Margin="0,24,0,14"
                            Content="发送验证码"
                            Style="{StaticResource SecondaryButton}"
                            Click="SendCodeButton_Click" />

                    <TextBlock Grid.Row="4"
                               Grid.ColumnSpan="2"
                               Text="验证码将发送至你的邮箱，10 分钟内有效。"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </Grid>
            </Grid>

            <DockPanel Grid.Row="4" LastChildFill="False" Margin="0,18,0,0">
                <TextBlock x:Name="HintText"
                           DockPanel.Dock="Left"
                           Width="300"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="你可以先登录，也可以先进入浏览模式。" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="跳过"
                            Width="96"
                            Style="{StaticResource SecondaryButton}"
                            Click="SkipButton_Click" />
                    <Button x:Name="ConfirmButton"
                            Width="112"
                            Margin="8,0,0,0"
                            Content="登录"
                            Style="{StaticResource PrimaryButton}"
                            Click="ConfirmButton_Click" />
                    <Button Content="关闭"
                            Width="96"
                            Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="CloseButton_Click" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
