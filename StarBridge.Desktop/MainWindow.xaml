                                                                                    <StackPanel.Style>
                                                                                        <Style TargetType="StackPanel">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding ShowPermissionControls}" Value="True">
                                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </StackPanel.Style>
                                                                                    <WrapPanel>
                                                                                        <CheckBox Content="移除成员"
                                                                                                  IsChecked="{Binding CanRemoveMembers}"
                                                                                                  IsEnabled="{Binding CanEditPermissions}"
                                                                                                  Foreground="{StaticResource PrimaryTextBrush}"
                                                                                                  Margin="0,0,18,8" />
                                                                                        <CheckBox Content="发布任务"
                                                                                                  IsChecked="{Binding CanPublishTasks}"
                                                                                                  IsEnabled="{Binding CanEditPermissions}"
                                                                                                  Foreground="{StaticResource PrimaryTextBrush}"
                                                                                                  Margin="0,0,18,8" />
                                                                                        <CheckBox Content="发布计划"
                                                                                                  IsChecked="{Binding CanPublishPlans}"
                                                                                                  IsEnabled="{Binding CanEditPermissions}"
                                                                                                  Foreground="{StaticResource PrimaryTextBrush}"
                                                                                                  Margin="0,0,18,8" />
                                                                                        <CheckBox Content="管理舰队信息"
                                                                                                  IsChecked="{Binding CanManageFleetInfo}"
                                                                                                  IsEnabled="{Binding CanEditPermissions}"
                                                                                                  Foreground="{StaticResource PrimaryTextBrush}"
                                                                                                  Margin="0,0,18,8" />
                                                                                    </WrapPanel>
                                                                                </StackPanel>
                                                                            </StackPanel>

                                                                            <Grid Grid.Column="4"
                                                                                  VerticalAlignment="Bottom">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <Button Content="保存权限"
                                                                                        Height="38"
                                                                                        Tag="{Binding}"
                                                                                        Click="SaveFleetMemberPermission_Click">
                                                                                    <Button.Style>
                                                                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding ShowSavePermissions}" Value="True">
                                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Button.Style>
                                                                                </Button>
                                                                                <Button Grid.Column="1"
                                                                                        Content="移除成员"
                                                                                        Style="{StaticResource SecondaryButton}"
                                                                                        Height="38"
                                                                                        Margin="8,0,0,0"
                                                                                        IsEnabled="{Binding CanRemoveFromFleet}"
                                                                                        Tag="{Binding}"
                                                                                        Click="RemoveFleetMember_Click" />
                                                                                <Button Grid.Column="2"
                                                                                        Content="转移指挥官"
                                                                                        Style="{StaticResource SecondaryButton}"
                                                                                        Height="38"
                                                                                        Margin="8,0,0,0"
                                                                                        IsEnabled="{Binding CanTransferCommander}"
                                                                                        Tag="{Binding}"
                                                                                        Click="TransferFleetCommander_Click" />
                                                                            </Grid>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>

                                            <TextBlock Grid.Row="2"
                                                       x:Name="FleetMemberManagementStatusText"
                                                       Margin="0,12,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </Grid>
                                    </Border>
                                </TabItem>
                                <TabItem x:Name="ManageFleetLogTab" Header="日志">
                                    <Border Style="{StaticResource HudPanel}"
                                            Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="FLEET EVENT LOG"
                                                           Style="{StaticResource HudCaptionText}" />
