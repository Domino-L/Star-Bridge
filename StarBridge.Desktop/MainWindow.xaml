                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding OwnerAvatarPath}" Value="{x:Null}">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                        <DataTrigger Binding="{Binding OwnerAvatarPath}" Value="">
                                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </Grid>
                                                                                </Border>
                                                                                <StackPanel Grid.Column="1"
                                                                                            VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding OwnerDisplay}"
                                                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                                                               FontWeight="SemiBold"
                                                                                               TextTrimming="CharacterEllipsis" />
                                                                                    <TextBlock Text="{Binding OwnerGameId}"
                                                                                               Style="{StaticResource HudCaptionText}"
                                                                                               Margin="0,3,0,0" />
                                                                                </StackPanel>
