                                    <Button Grid.Column="2"
                                            x:Name="CreateFleetSubmitButton"
                                            Content="创建舰队"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="8,0,0,0"
                                            Click="CreateFleetSubmit_Click" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
