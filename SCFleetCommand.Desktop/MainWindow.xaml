<Window x:Class="SCFleetCommand.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Star Bridge"
        Width="1664"
        Height="988"
        MinWidth="1404"
        MinHeight="884"
        Closing="MainWindow_Closing"
        StateChanged="MainWindow_StateChanged">
    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Rectangle Fill="{StaticResource VerticalStreakBrush}"
                   IsHitTestVisible="False" />
        <Rectangle Fill="{StaticResource ScanlineBrush}"
                   IsHitTestVisible="False" />
        <Border VerticalAlignment="Top"
                Height="4"
                Background="{StaticResource AccentDimBrush}"
                Opacity="0.72"
                IsHitTestVisible="False" />

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="365" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="0,0,1,1"
                    Background="#B0040A11">
                <Image Source="/Assets/Brand/StarBridge_logo.png"
                       Stretch="Uniform"
                       Width="350"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0" />
            </Border>

            <Button Grid.Column="1"
                    x:Name="FindFleetNavButton"
                    Style="{StaticResource NavButton}"
                    Click="FindFleetNav_Click">
                <StackPanel>
                    <TextBlock Text="FIND" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="FindFleetNavText" Text="Find Fleet" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    x:Name="MyFleetNavButton"
                    Style="{StaticResource NavButton}"
                    Click="MyFleetNav_Click">
                <StackPanel>
                    <TextBlock Text="FLEET" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="MyFleetNavText" Text="My Fleet" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="3"
                    x:Name="MySquadNavButton"
                    Style="{StaticResource NavButton}"
                    Click="MySquadNav_Click">
                <StackPanel>
                    <TextBlock Text="SQ" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="MySquadNavText" Text="My Squad" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="4"
                    x:Name="OverlayNavButton"
                    Style="{StaticResource NavButton}"
                    Click="OverlayNav_Click">
                <StackPanel>
                    <TextBlock Text="HUD" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="OverlayNavText" Text="Overlay" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="5"
                    x:Name="PersonalNavButton"
                    Style="{StaticResource NavButton}"
                    Margin="0"
                    Click="PersonalNav_Click">
                <StackPanel>
                    <TextBlock Text="ID" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                    <TextBlock x:Name="PersonalNavText" Text="Personal" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="138" />
                <ColumnDefinition Width="104" />
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="138" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Star Bridge"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />

            <TextBox Grid.Column="0"
                     x:Name="LogPathBox"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Text="No Game.log selected" />

            <Button Grid.Column="1"
                    x:Name="SelectLogButton"
                    Margin="12,0,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Content="Select Log"
                    Click="SelectLog_Click" />

            <ComboBox Grid.Column="2"
                      x:Name="LanguageBox"
                      Margin="12,0,0,0"
                      VerticalContentAlignment="Center"
                      SelectionChanged="LanguageBox_SelectionChanged">
                <ComboBoxItem Content="English" Tag="en" />
                <ComboBoxItem Content="中文" Tag="zh" />
            </ComboBox>

            <TextBox Grid.Column="3"
                     x:Name="OverlayHotkeyBox"
                     Margin="12,0,0,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Text="F8"
                     ToolTip="Click here, then press a custom overlay hotkey."
                     GotKeyboardFocus="OverlayHotkeyBox_GotKeyboardFocus"
                     PreviewKeyDown="OverlayHotkeyBox_PreviewKeyDown" />

            <Button Grid.Column="4"
                    x:Name="ToggleOverlayButton"
                    Margin="12,0,0,0"
                    Style="{StaticResource SecondaryButton}"
                    Content="Toggle Overlay"
                    Click="OpenOverlay_Click" />
        </Grid>

        <TabControl x:Name="MainTabs"
                    Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent" />
                </ControlTemplate>
            </TabControl.Template>
            <TabItem x:Name="FindFleetTab" Header="Find Fleet">
                <Border Margin="0,14,0,0"
                        Style="{StaticResource HudPanel}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="FindFleetTitleText"
                                   Text="Find Fleet"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Grid.Row="1"
                                   x:Name="FindFleetPlaceholderText"
                                   Text="Fleet discovery prototype area. Later this can show public fleets, search, filters, and join requests."
                                   Margin="0,22,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </TabItem>
            <TabItem x:Name="FleetTab" Header="Fleet">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="172" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource HudPanel}"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="560" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="300" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="118" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="96"
                                        Height="96"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource FieldBackBrush}">
                                    <Grid>
                                        <Image x:Name="FleetHeaderLogoImage" Stretch="UniformToFill" />
                                        <TextBlock x:Name="FleetHeaderLogoText"
                                                   Text="LOGO"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Column="1"
                                      Margin="12,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="34" />
                                        <RowDefinition Height="26" />
                                        <RowDefinition Height="26" />
                                        <RowDefinition Height="26" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="FleetHeaderNameText"
                                                   Text="Fleet Name"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   MaxWidth="360"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   x:Name="FleetHeaderCodeText"
                                                   Text="CODE"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Margin="12,6,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               x:Name="FleetCommanderText"
                                               Text="首席指挥官 / Unassigned"
                                               Style="{StaticResource HudCaptionText}" />
                                    <TextBlock Grid.Row="2"
                                               x:Name="FleetDeputyCommanderText"
                                               Text="副指挥官 / Unassigned"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Grid.Row="3"
                                               x:Name="FleetTypeSummaryText"
                                               Text="类型 / Standby"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>
                            </Grid>

                            <StackPanel Grid.Column="1"
                                        Margin="28,0,18,0">
                                <TextBlock x:Name="FleetActionPlanLabel"
                                           Text="行动计划"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,0,0,8" />
                                <Border x:Name="FleetActionPlanCard"
                                        MinHeight="96"
                                        Padding="12"
                                        BorderBrush="{StaticResource AccentDimBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource FieldBackBrush}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="FleetActionPlanCard_MouseLeftButtonUp">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="112" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="FleetActionPlanTitleText"
                                                       Text="暂无行动计划，等待下一步指挥"
                                                       Foreground="{StaticResource PrimaryTextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock x:Name="FleetActionPlanSummaryText"
                                                       Text=""
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="46" />
                                            <TextBlock x:Name="FleetActionPlanTimeText"
                                                       Text=""
                                                       Margin="0,8,0,0"
                                                       Style="{StaticResource HudCaptionText}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                x:Name="JoinFleetActionButton"
                                                Content="参与"
                                                Style="{StaticResource PrimaryButton}"
                                                Height="36"
                                                VerticalAlignment="Center"
                                                Visibility="Collapsed"
                                                Click="JoinFleetActionButton_Click" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource HudPanel}" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock x:Name="TotalMembersLabel" Text="人数" Style="{StaticResource HudCaptionText}" />
                                        <TextBlock x:Name="TotalMembersText" Text="0" Style="{StaticResource HudValueText}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource HudPanel}" Margin="4,0">
                                    <StackPanel>
                                        <TextBlock x:Name="FleetShipsLabel" Text="舰船" Style="{StaticResource HudCaptionText}" />
                                        <TextBlock x:Name="FleetShipCountText" Text="0" Style="{StaticResource HudValueText}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource HudPanel}" Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="OnlineLabel" Text="在线" Style="{StaticResource HudCaptionText}" />
                                        <TextBlock x:Name="OnlineMembersText" Text="0" Style="{StaticResource HudValueText}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <TabControl x:Name="FleetSubTabs" Grid.Row="1">
                        <TabItem x:Name="AllPlayersTab" Header="All Players">
                            <ScrollViewer Margin="0,14,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          Background="{StaticResource FieldBackBrush}"
                                          BorderBrush="{StaticResource AccentDimBrush}">
                                <ItemsControl x:Name="PlayersList"
                                              Margin="10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SquadBannerPanel}"
                                                    MinHeight="92"
                                                    Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="170" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="220" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Width="52"
                                                            Height="52"
                                                            VerticalAlignment="Center"
                                                            Background="{StaticResource FieldBackBrush}"
                                                            BorderBrush="{StaticResource AccentBrush}"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Image Source="{Binding AvatarPath}" Stretch="UniformToFill" />
                                                            <TextBlock Text="{Binding Initials}"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="SQUAD" Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Text="{Binding SquadName}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="ROLE" Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Text="{Binding Role}" Foreground="{StaticResource PrimaryTextBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                        <TextBlock Text="CALLSIGN" Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Text="{Binding Callsign}" Foreground="{StaticResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                        <TextBlock Text="GAME ID" Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                                        <TextBlock Text="ONLINE" Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource AccentBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="6" VerticalAlignment="Center">
                                                        <TextBlock Text="SHIP" Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Text="{Binding Ship}" Foreground="{StaticResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="7" VerticalAlignment="Center">
                                                        <TextBlock Text="LOCATION" Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Text="{Binding Location}" Foreground="{StaticResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem x:Name="SquadsTab" Header="Squads">
                            <ScrollViewer Margin="0,14,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="SquadsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SquadBannerPanel}"
                                                    MinHeight="132">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="96" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="280" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0">
                                                        <Border Width="72"
                                                                Height="72"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Background="{StaticResource FieldBackBrush}"
                                                                BorderBrush="{StaticResource AccentBrush}"
                                                                BorderThickness="1">
                                                            <Grid>
                                                                <Image Source="{Binding EmblemPath}"
                                                                       Stretch="UniformToFill" />
                                                                <TextBlock Text="{Binding Icon}"
                                                                           FontSize="28"
                                                                           FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding EmblemPath}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>
                                                        <Button Width="72"
                                                                Height="28"
                                                                Margin="0,80,0,0"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Content="EMBLEM"
                                                                Tag="{Binding}"
                                                                Click="ChooseSquadEmblem_Click" />
                                                    </Grid>

                                                    <Grid Grid.Column="1"
                                                          Margin="4,0,18,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="34" />
                                                            <RowDefinition Height="26" />
                                                            <RowDefinition Height="26" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="22"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentBrush}" />
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding CommanderLine}"
                                                                   Style="{StaticResource HudCaptionText}" />
                                                        <TextBlock Grid.Row="2"
                                                                   Text="{Binding MissionLine}"
                                                                   Foreground="{StaticResource AccentBrush}" />
                                                        <TextBlock Grid.Row="3"
                                                                   Text="{Binding RallyLine}"
                                                                   Foreground="{StaticResource MutedTextBrush}" />
                                                    </Grid>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{Binding SummaryLine}"
                                                                   Style="{StaticResource HudCaptionText}"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="0,0,0,12" />
                                                        <ItemsControl ItemsSource="{Binding Members}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel HorizontalAlignment="Right" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Width="58"
                                                                                Margin="4,0,0,8">
                                                                        <Border Width="42"
                                                                                Height="42"
                                                                                HorizontalAlignment="Center"
                                                                                CornerRadius="21"
                                                                                Background="{StaticResource FieldBackBrush}"
                                                                                BorderBrush="{StaticResource AccentBrush}"
                                                                                BorderThickness="1">
                                                                            <TextBlock Text="{Binding Initials}"
                                                                                       Foreground="{StaticResource AccentBrush}"
                                                                                       FontWeight="SemiBold"
                                                                                       HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center" />
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontSize="9"
                                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                                   TextAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                    <Border x:Name="ActionPlanEditorPanel"
                            Grid.RowSpan="2"
                            Panel.ZIndex="50"
                            Width="720"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            Style="{StaticResource HudPanel}"
                            Padding="24">
                        <StackPanel>
                            <TextBlock Text="设定行动计划"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <Grid Margin="0,20,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="行动标题：" Grid.Row="0" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBox x:Name="ActionPlanTitleBox" Grid.Row="0" Grid.Column="1" MaxLength="48" />

                                <TextBlock Text="行动内容：" Grid.Row="1" Margin="0,14,0,0" VerticalAlignment="Top" Foreground="{StaticResource PrimaryTextBrush}" />
                                <TextBox x:Name="ActionPlanContentBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Height="120"
                                         Margin="0,14,0,0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxLength="500" />

                                <TextBlock Text="行动时间：" Grid.Row="2" Margin="0,14,0,0" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}" />
                                <Grid Grid.Row="2" Grid.Column="1" Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <DatePicker x:Name="ActionPlanDatePicker" />
                                    <TextBox Grid.Column="1"
                                             x:Name="ActionPlanTimeBox"
                                             Margin="12,0,0,0"
                                             MaxLength="5"
                                             Text="20:00"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="只能设定现在开始的 7 天之内，24 小时制 HH:mm"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>

                                <CheckBox x:Name="ActionPlanNotifyFleetCheck"
                                          Grid.Row="3"
                                          Grid.ColumnSpan="2"
                                          Margin="0,18,0,0"
                                          Content="是否向舰队成员发送通知（需要舰队成员同意接收；联网后发送到注册邮箱）" />
                            </Grid>
                            <TextBlock x:Name="ActionPlanValidationText"
                                       Foreground="#FFFF6969"
                                       Margin="0,16,0,0" />
                            <Grid Margin="0,22,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1"
                                        Content="取消"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="8,0,0,0"
                                        Click="CancelActionPlanButton_Click" />
                                <Button Grid.Column="2"
                                        Content="发布"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="8,0,0,0"
                                        Click="PublishActionPlanButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="JoinActionPlanPanel"
                            Grid.RowSpan="2"
                            Panel.ZIndex="55"
                            Width="420"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            Style="{StaticResource HudPanel}"
                            Padding="24">
                        <StackPanel>
                            <TextBlock Text="参与"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock x:Name="JoinActionPlanTitleText"
                                       Text="行动计划"
                                       Margin="0,14,0,18"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                            <CheckBox x:Name="JoinActionNotifyCheck"
                                      Content="是否在开始时通知？（开始前 5 分钟向邮箱发送即将开始信息）" />
                            <Grid Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="130" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1"
                                        Content="取消"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="8,0,0,0"
                                        Click="CancelJoinActionPlanButton_Click" />
                                <Button Grid.Column="2"
                                        Content="确认"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="8,0,0,0"
                                        Click="ConfirmJoinActionPlanButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FleetEmptyPanel"
                            Grid.RowSpan="2"
                            Panel.ZIndex="20"
                            Background="{StaticResource PageBackgroundBrush}"
                            BorderBrush="{StaticResource AccentDimBrush}"
                            BorderThickness="1"
                            Padding="28">
                        <Grid>
                            <StackPanel Width="520"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="FleetEmptyTitleText"
                                           Text="尚未加入舰队"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="FleetEmptyHintText"
                                           Text="寻找或创建一个舰队"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="15"
                                           Margin="0,12,0,28"
                                           HorizontalAlignment="Center" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            x:Name="FleetFindButton"
                                            Content="寻找舰队"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="44"
                                            Margin="0,0,8,0"
                                            Click="FleetFindButton_Click" />
                                    <Button Grid.Column="1"
                                            x:Name="FleetCreateButton"
                                            Content="创建舰队"
                                            Style="{StaticResource PrimaryButton}"
                                            Height="44"
                                            Margin="8,0,0,0"
                                            Click="FleetCreateButton_Click" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="FleetCreatePanel"
                            Grid.RowSpan="2"
                            Panel.ZIndex="30"
                            Visibility="Collapsed"
                            Background="{StaticResource PageBackgroundBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            Padding="0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="42,36,42,42">
                                <TextBlock x:Name="CreateFleetTitleText"
                                           Text="创建舰队"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock x:Name="CreateFleetSubtitleText"
                                           Text="填写基础资料、运营设置与加入规则。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,10,0,22" />
                                <Border Height="4"
                                        Background="{StaticResource AccentBrush}"
                                        Margin="0,0,0,22" />

                                <TextBlock Text="基础信息" Style="{StaticResource HudCaptionText}" FontSize="15" />
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Width="120"
                                            Height="120"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="ChooseFleetLogo_Click">
                                        <Grid>
                                            <Image x:Name="CreateFleetLogoImage" Stretch="UniformToFill" />
                                            <TextBlock x:Name="CreateFleetLogoText"
                                                       Text="LOGO"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>

                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                            <TextBlock Text="舰队名称" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                                            <TextBox x:Name="CreateFleetNameBox"
                                                     Margin="0,8,0,4"
                                                     MaxLength="30"
                                                     TextChanged="CreateFleetField_TextChanged" />
                                            <TextBlock x:Name="CreateFleetNameHintText"
                                                       Text="仅允许英文，最多 30 个字符"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                            <TextBlock Text="舰队简称" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                                            <TextBox x:Name="CreateFleetCodeBox"
                                                     Margin="0,8,0,4"
                                                     MaxLength="10"
                                                     TextChanged="CreateFleetField_TextChanged" />
                                            <TextBlock x:Name="CreateFleetCodeHintText"
                                                       Text="仅允许英文，最多 10 个字符"
                                                       Foreground="{StaticResource MutedTextBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <TextBlock Text="简介" Style="{StaticResource HudCaptionText}" FontSize="15" Margin="0,28,0,8" />
                                <TextBox x:Name="CreateFleetIntroBox"
                                         Height="110"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MaxLength="300" />

                                <TextBlock Text="运营信息" Style="{StaticResource HudCaptionText}" FontSize="15" Margin="0,28,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                        <TextBlock Text="语言" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                                        <ComboBox x:Name="CreateFleetLanguageBox" Margin="0,8,0,0" SelectedIndex="0">
                                            <ComboBoxItem Content="中文" />
                                            <ComboBoxItem Content="English" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                        <TextBlock Text="活动时间段 北京时间 UTC+8" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="SemiBold" />
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="44" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="CreateFleetOnlineFromBox"
                                                     Text="20:00"
                                                     MaxLength="5"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="CreateFleetField_TextChanged" />
                                            <TextBlock Grid.Column="1" Text="to" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBox Grid.Column="2"
                                                     x:Name="CreateFleetOnlineToBox"
                                                     Text="23:59"
                                                     MaxLength="5"
                                                     VerticalContentAlignment="Center"
                                                     TextChanged="CreateFleetField_TextChanged" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="舰队类型" Style="{StaticResource HudCaptionText}" FontSize="15" Margin="0,28,0,12" />
                                <WrapPanel>
                                    <RadioButton Content="战斗" GroupName="FleetType" IsChecked="True" Margin="0,0,18,10" />
                                    <RadioButton Content="探索" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="救援" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="采矿" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="贸易" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="自由" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="海盗" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="货运" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="走私" GroupName="FleetType" Margin="0,0,18,10" />
                                    <RadioButton Content="社交" GroupName="FleetType" Margin="0,0,18,10" />
                                </WrapPanel>

                                <TextBlock Text="舰队设置" Style="{StaticResource HudCaptionText}" FontSize="15" Margin="0,24,0,12" />
                                <StackPanel>
                                    <CheckBox x:Name="CreateFleetShipDatabaseCheck"
                                              Content="启用舰船数据库（共享舰船与拥有者数据）"
                                              Margin="0,0,0,10" />
                                    <CheckBox x:Name="CreateFleetShowShipsCheck"
                                              Content="展示舰队飞船"
                                              IsEnabled="{Binding IsChecked, ElementName=CreateFleetShipDatabaseCheck}"
                                              Margin="24,0,0,10" />
                                    <CheckBox x:Name="CreateFleetOperationNoticeCheck"
                                              Content="启用行动通知（创建行动将会邮件通知舰队成员）"
                                              Margin="0,0,0,10" />
                                </StackPanel>

                                <TextBlock Text="语音频道（可选）" Style="{StaticResource HudCaptionText}" FontSize="15" Margin="0,22,0,8" />
                                <TextBox x:Name="CreateFleetVoiceChannelBox"
                                         VerticalContentAlignment="Center"
                                         ToolTip="粘贴 Discord、KOOK 或其他语音频道链接" />

                                <TextBlock Text="谁可加入舰队？" Style="{StaticResource HudCaptionText}" FontSize="15" Margin="0,28,0,12" />
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="无门槛" GroupName="FleetJoinPolicy" IsChecked="True" Margin="0,0,18,0" />
                                    <RadioButton Content="需要申请" GroupName="FleetJoinPolicy" />
                                </StackPanel>
                                <Grid Margin="0,28,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CreateFleetValidationText"
                                               Foreground="#FFFF6969"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="取消"
                                            Style="{StaticResource SecondaryButton}"
                                            Margin="8,0,0,0"
                                            Click="CreateFleetCancel_Click" />
                                    <Button Grid.Column="2"
                                            x:Name="CreateFleetSubmitButton"
                                            Content="创建舰队"
                                            Style="{StaticResource PrimaryButton}"
                                            Margin="8,0,0,0"
                                            Click="CreateFleetSubmit_Click" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="MySquadTab" Header="My Squad">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="230" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource HudPanel}"
                            Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="172"
                                    Height="172"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource FieldBackBrush}"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="MySquadEmblem_MouseLeftButtonUp">
                                <Grid Width="172" Height="172">
                                    <Image x:Name="MySquadEmblemImage"
                                           Stretch="UniformToFill" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="MySquadIconText"
                                                   Text="A"
                                                   FontSize="44"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock x:Name="MySquadEmblemHintText"
                                                   Text="Click to change"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="1"
                                  Margin="24,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="42" />
                                    <RowDefinition Height="36" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="MySquadNameText"
                                           Text="Alpha"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Grid.Row="1"
                                           x:Name="MySquadCommanderText"
                                           Text="Commander / Unassigned"
                                           Style="{StaticResource HudCaptionText}" />
                                <Border Grid.Row="2"
                                        BorderBrush="{StaticResource AccentDimBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource FieldBackBrush}"
                                        Padding="18"
                                        Margin="0,8,0,0">
                                    <TextBox x:Name="MySquadDescriptionBox"
                                             Text="No squad briefing yet."
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             TextChanged="MySquadDescriptionBox_TextChanged" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <ListView Grid.Row="1"
                              x:Name="MySquadMembersList"
                              Margin="0,14,0,0"
                              Background="{StaticResource FieldBackBrush}"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              BorderBrush="{StaticResource AccentDimBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn x:Name="MySquadAvatarColumn" Header="Avatar" Width="86">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="38"
                                                    Height="38"
                                                    Background="{StaticResource FieldBackBrush}"
                                                    BorderBrush="{StaticResource AccentDimBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding AvatarPath}"
                                                           Stretch="UniformToFill" />
                                                    <TextBlock Text="{Binding Avatar}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="MySquadRoleColumn" Header="Role" DisplayMemberBinding="{Binding Role}" Width="110" />
                                <GridViewColumn x:Name="MySquadCallsignColumn" Header="Callsign" DisplayMemberBinding="{Binding Callsign}" Width="140" />
                                <GridViewColumn x:Name="MySquadGameIdColumn" Header="Game ID" DisplayMemberBinding="{Binding GameId}" Width="190" />
                                <GridViewColumn x:Name="MySquadOnlineColumn" Header="Online" DisplayMemberBinding="{Binding OnlineStatus}" Width="130" />
                                <GridViewColumn x:Name="MySquadShipColumn" Header="Ship Status" DisplayMemberBinding="{Binding ShipStatus}" Width="260" />
                                <GridViewColumn x:Name="MySquadLocationColumn" Header="Location" DisplayMemberBinding="{Binding Location}" Width="260" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border x:Name="SquadRequiresFleetPanel"
                            Grid.RowSpan="2"
                            Panel.ZIndex="20"
                            Background="{StaticResource PageBackgroundBrush}"
                            BorderBrush="{StaticResource AccentDimBrush}"
                            BorderThickness="1"
                            Padding="28">
                        <StackPanel Width="560"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="SquadRequiresFleetTitleText"
                                       Text="尚未加入舰队"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="SquadRequiresFleetHintText"
                                       Text="需要先加入或创建舰队，才可以加入或创建小队。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="15"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,28" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        x:Name="SquadFindFleetButton"
                                        Content="寻找舰队"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="44"
                                        Margin="0,0,8,0"
                                        Click="FleetFindButton_Click" />
                                <Button Grid.Column="1"
                                        x:Name="SquadCreateFleetButton"
                                        Content="创建舰队"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="44"
                                        Margin="8,0,0,0"
                                        Click="FleetCreateButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="OverlayEditTab" Header="Overlay Edit">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               x:Name="OverlayEditHintText"
                               Text="Drag panels to move. Drag the lower-right handle to resize. Saved layout is applied to fullscreen Overlay."
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Style="{StaticResource HudPanel}"
                            Padding="14"
                            Margin="0,0,12,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            x:Name="SaveLayoutButton"
                                            Margin="0,0,6,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="Save Layout"
                                            Click="SaveOverlayLayout_Click" />
                                    <Button Grid.Column="1"
                                            x:Name="ResetLayoutButton"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Content="Reset"
                                            Click="ResetOverlayLayout_Click" />
                                </Grid>

                                <TextBlock x:Name="OverlayOptionsLabel" Text="OVERLAY OPTIONS" Style="{StaticResource HudCaptionText}" Margin="0,0,0,8" />
                                <CheckBox x:Name="ShowNoticePanelCheck"
                                          Content="Show fleet notice"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="ShowSquadsPanelCheck"
                                          Content="Show squad list"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="ShowMissionPanelCheck"
                                          Content="Show task panel"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="ShowMembersPanelCheck"
                                          Content="Show member status"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="HideMissionWhenIdleCheck"
                                          Content="No task: hide right mission overlay"
                                          Margin="0,14,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="HideOfflineMembersCheck"
                                          Content="Hide offline squad members"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="HideSquadIconsCheck"
                                          Content="Left panel: hide squad icons"
                                          Margin="0,8,0,18"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />

                                <TextBlock x:Name="MemberNameDisplayLabel" Text="MEMBER NAME DISPLAY" Style="{StaticResource HudCaptionText}" Margin="0,0,0,8" />
                                <RadioButton x:Name="ShowCallsignAndNameRadio"
                                             Content="Show callsign and game name"
                                             GroupName="OverlayMemberName"
                                             Checked="OverlaySetting_Changed" />
                                <RadioButton x:Name="ShowCallsignOnlyRadio"
                                             Content="Only callsign"
                                             GroupName="OverlayMemberName"
                                             Margin="0,8,0,0"
                                             Checked="OverlaySetting_Changed" />
                                <RadioButton x:Name="ShowGameNameOnlyRadio"
                                             Content="Only game name"
                                             GroupName="OverlayMemberName"
                                             Margin="0,8,0,18"
                                             Checked="OverlaySetting_Changed" />

                                <TextBlock x:Name="BackgroundModeLabel" Text="BACKGROUND" Style="{StaticResource HudCaptionText}" Margin="0,0,0,8" />
                                <TextBlock x:Name="OverlayOpacityLabel"
                                           Text="OPACITY"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,0,0,8" />
                                <Slider x:Name="OverlayOpacitySlider"
                                        Minimum="15"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="False"
                                        ValueChanged="OverlayOpacitySlider_ValueChanged" />
                                <TextBlock x:Name="OverlayOpacityValueText"
                                           Text="85%"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,4,0,14" />
                                <CheckBox x:Name="TrayModeCheck"
                                          Content="Tray / background mode"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <TextBlock x:Name="TrayModeHintText"
                                           Text="When enabled, closing or minimizing hides this window but keeps the hotkey alive."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource HudPanel}"
                            Padding="10"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top">
                        <Viewbox Stretch="Uniform"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top">
                            <Canvas x:Name="OverlayEditorCanvas"
                                    Width="1600"
                                    Height="900"
                                    Background="#CC000000"
                                    SizeChanged="OverlayEditorCanvas_SizeChanged" />
                        </Viewbox>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="PersonalTab" Header="Personal">
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource HudPanel}">
                        <StackPanel>
                            <Border Height="220"
                                    Background="{StaticResource FieldBackBrush}"
                                    BorderBrush="{StaticResource AccentDimBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Image x:Name="AvatarImage"
                                           Stretch="UniformToFill" />
                                    <TextBlock x:Name="AvatarPlaceholderText"
                                               Text="AVATAR"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Button Margin="0,16,0,0"
                                    Style="{StaticResource SecondaryButton}"
                                    x:Name="ChooseAvatarButton"
                                    Content="Choose Avatar"
                                    Click="ChooseAvatar_Click" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource HudPanel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="PlayerNameLabel" Text="Player Name" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="GameNameText" Grid.Column="1" Text="Waiting for Game.log identity" />
                            <TextBlock x:Name="PlayerIdLabel" Grid.Row="1" Text="Player ID" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="PlayerIdText" Grid.Row="1" Grid.Column="1" Text="Waiting for playerGEID" />
                            <TextBlock x:Name="CallsignLabel" Grid.Row="2" Text="Callsign" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBox x:Name="CallsignBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     TextChanged="CallsignBox_TextChanged" />
                            <TextBlock x:Name="FleetLabel" Grid.Row="3" Text="Fleet" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="LocalFleetText" Grid.Row="3" Grid.Column="1" Text="Local Fleet" />
                            <TextBlock x:Name="StatusLabel" Grid.Row="4" Text="Status" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock x:Name="ProfileStatusText" Grid.Row="4" Grid.Column="1" Text="Identity Required" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="MonitorTab" Header="Monitor">
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource HudPanel}">
                        <TextBlock x:Name="ShipStateText"
                                   Text="Current Ship: Unknown&#x0a;Driving Ship: None&#x0a;Control Signal: None"
                                   TextWrapping="Wrap" />
                    </Border>
                    <TextBox Grid.Column="1"
                             x:Name="OutputBox"
                             FontFamily="Cascadia Mono"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
    </Grid>
</Window>

