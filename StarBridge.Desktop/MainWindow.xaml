                                                    <ComboBoxItem Content="任务" Tag="任务" />
                                                    <ComboBoxItem Content="公告" Tag="公告" />
                                                    <ComboBoxItem Content="计划" Tag="计划" />
                                                    <ComboBoxItem Content="舰队" Tag="舰队" />
                                                </ComboBox>
                                                <TextBox Grid.Column="1"
                                                         x:Name="FleetLogSearchBox"
                                                         Height="36"
                                                         Margin="12,0,0,0"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="FleetLogFilter_Changed" />
                                            </Grid>
                                            <Border Grid.Row="2"
                                                    Background="{StaticResource FieldBackBrush}"
                                                    BorderBrush="{StaticResource AccentDimBrush}"
