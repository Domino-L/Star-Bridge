                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="拉取远端"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="NetworkPullButton_Click" />
