                                                                            <TextBlock Grid.Column="2"
                                                                                       Text="{Binding ShipCode}"
                                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                                       VerticalAlignment="Center"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                            <Grid Grid.Column="3"
                                                                                  VerticalAlignment="Center">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="48" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <Border Width="38"
                                                                                        Height="38"
                                                                                        Background="{StaticResource FieldBackBrush}"
                                                                                        BorderBrush="{StaticResource AccentBrush}"
                                                                                        BorderThickness="1">
                                                                                    <Grid>
                                                                                        <Image Source="{Binding OwnerAvatarPath, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill" />
                                                                                        <TextBlock Text="{Binding OwnerInitials}"
