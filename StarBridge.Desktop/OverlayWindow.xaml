<Window x:Class="StarBridge.Desktop.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fleet Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Focusable="False"
        ShowActivated="False"
        ShowInTaskbar="False"
        KeyDown="OverlayWindow_KeyDown">
    <Window.Resources>
        <Style x:Key="OverlayPanel" TargetType="Border">
            <Setter Property="Background" Value="{Binding PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{Binding PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="OverlayTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding TitleBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="OverlayText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding TextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="OverlayMuted" TargetType="TextBlock" BasedOn="{StaticResource OverlayText}">
            <Setter Property="Foreground" Value="{Binding MutedBrush}" />
            <Setter Property="FontSize" Value="10" />
        </Style>
        <Style x:Key="OverlayCornerPath" TargetType="Path">
            <Setter Property="Stroke" Value="{Binding TitleBrush}" />
            <Setter Property="StrokeThickness" Value="1.4" />
            <Setter Property="Opacity" Value="0.86" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style x:Key="OverlayScanPath" TargetType="Path">
            <Setter Property="Stroke" Value="{Binding PanelBorderBrush}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Opacity" Value="0.32" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
    </Window.Resources>

    <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False" Opacity="{Binding OverlayOpacity}">
        <Border x:Name="NoticePanel"
                Style="{StaticResource OverlayPanel}"
                Visibility="{Binding NotificationVisibility}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="10,8,14,8">
                    <TextBlock Text="{Binding FleetNoticeTitle}" Style="{StaticResource OverlayTitle}" />
                    <TextBlock Text="{Binding FleetNotice}" Style="{StaticResource OverlayText}" Margin="0,6,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding NoticeTimerLabel}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{Binding AlertBrush}"
                           FontWeight="SemiBold" />
                <Path Grid.ColumnSpan="2"
                      Style="{StaticResource OverlayScanPath}"
                      Data="M42,0 L150,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Grid.ColumnSpan="2"
                      Style="{StaticResource OverlayScanPath}"
                      Data="M0,18 L0,60"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Grid.ColumnSpan="2"
                      Style="{StaticResource OverlayCornerPath}"
                      Data="M0,18 L0,5 L5,0 L28,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Grid.ColumnSpan="2"
                      Style="{StaticResource OverlayCornerPath}"
                      Data="M6,0 L29,0 L34,5 L34,18"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Grid.ColumnSpan="2"
                      Style="{StaticResource OverlayCornerPath}"
                      Data="M0,4 L0,17 L5,22 L28,22"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
                <Path Grid.ColumnSpan="2"
                      Style="{StaticResource OverlayCornerPath}"
                      Data="M6,22 L29,22 L34,17 L34,4"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
            </Grid>
        </Border>

        <Border x:Name="SquadsPanel" Style="{StaticResource OverlayPanel}" Visibility="{Binding SquadsVisibility}">
            <Grid>
                <StackPanel Margin="10,8,14,8">
                    <TextBlock Text="{Binding SquadsTitle}" Style="{StaticResource OverlayTitle}" />
                    <ItemsControl ItemsSource="{Binding Squads}" Margin="0,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,12">
                                    <Border Width="38"
                                            Height="38"
                                            Margin="0,0,10,0"
                                            DockPanel.Dock="Left"
                                            Visibility="{Binding IconVisibility}"
                                            Background="{Binding DataContext.IconBackgroundBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                            BorderBrush="{Binding DataContext.PanelBorderBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Image Source="{Binding EmblemPath}" Stretch="UniformToFill" />
                                            <TextBlock Text="{Binding Icon}"
                                                       Visibility="{Binding IconTextVisibility}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding DataContext.TitleBrush, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{Binding DataContext.TextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CommanderLine}"
                                                   Foreground="{Binding DataContext.MutedBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                                   FontSize="10" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <Path Style="{StaticResource OverlayScanPath}"
                      Data="M0,34 L0,120"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Style="{StaticResource OverlayScanPath}"
                      Data="M30,0 L120,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M0,18 L0,5 L5,0 L28,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M6,0 L29,0 L34,5 L34,18"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M0,4 L0,17 L5,22 L28,22"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M6,22 L29,22 L34,17 L34,4"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
            </Grid>
        </Border>

        <Border x:Name="MissionPanel" Style="{StaticResource OverlayPanel}" Visibility="{Binding MissionVisibility}">
            <Grid>
                <StackPanel Margin="10,8,14,8">
                    <TextBlock Text="{Binding MissionTitle}" Style="{StaticResource OverlayTitle}" />
                    <TextBlock Text="{Binding FleetMission}" Style="{StaticResource OverlayText}" Margin="0,12,0,0" />
                    <TextBlock Text="{Binding SquadMission}" Style="{StaticResource OverlayText}" Margin="0,6,0,0" />
                    <TextBlock Text="{Binding RallyPoint}" Foreground="{Binding AlertBrush}" FontSize="12" Margin="0,6,0,0" />
                </StackPanel>
                <Path Style="{StaticResource OverlayScanPath}"
                      Data="M40,0 L160,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Style="{StaticResource OverlayScanPath}"
                      Data="M0,28 L0,90"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M0,18 L0,5 L5,0 L28,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M6,0 L29,0 L34,5 L34,18"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M0,4 L0,17 L5,22 L28,22"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M6,22 L29,22 L34,17 L34,4"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
            </Grid>
        </Border>

        <Border x:Name="MembersPanel" Style="{StaticResource OverlayPanel}" Visibility="{Binding MembersVisibility}">
            <Grid>
                <StackPanel Margin="10,8,14,8">
                    <TextBlock Text="{Binding MembersTitle}" Style="{StaticResource OverlayTitle}" />
                    <ItemsControl ItemsSource="{Binding Members}" Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,9">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="{Binding DataContext.TextBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Status}"
                                               Foreground="{Binding StatusBrush}"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Location}"
                                               Foreground="{Binding DataContext.MutedBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontSize="10"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Right"
                                               TextAlignment="Right" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="3"
                                               Text="{Binding Ship}"
                                               Foreground="{Binding DataContext.MutedBrush, RelativeSource={RelativeSource AncestorType=Window}}"
                                               FontSize="10"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <Path Style="{StaticResource OverlayScanPath}"
                      Data="M0,32 L0,110"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Style="{StaticResource OverlayScanPath}"
                      Data="M36,0 L150,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M0,18 L0,5 L5,0 L28,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M6,0 L29,0 L34,5 L34,18"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M0,4 L0,17 L5,22 L28,22"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
                <Path Style="{StaticResource OverlayCornerPath}"
                      Data="M6,22 L29,22 L34,17 L34,4"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Panel.ZIndex="3" />
            </Grid>
        </Border>

        <Grid Visibility="{Binding CrosshairVisibility}"
              Width="{Binding ActualWidth, ElementName=OverlayCanvas}"
              Height="{Binding ActualHeight, ElementName=OverlayCanvas}"
              IsHitTestVisible="False">
            <Viewbox Width="{Binding CrosshairSize}"
                     Height="{Binding CrosshairSize}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Opacity="{Binding CrosshairOpacity}"
                     Visibility="{Binding SimpleCrosshairVisibility}">
                <Grid Width="96" Height="96">
                    <Line X1="48" Y1="10" X2="48" Y2="34"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding SimpleCrosshairStrokeThickness}"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square" />
                    <Line X1="48" Y1="62" X2="48" Y2="86"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding SimpleCrosshairStrokeThickness}"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square" />
                    <Line X1="10" Y1="48" X2="34" Y2="48"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding SimpleCrosshairStrokeThickness}"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square" />
                    <Line X1="62" Y1="48" X2="86" Y2="48"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding SimpleCrosshairStrokeThickness}"
                          StrokeStartLineCap="Square"
                          StrokeEndLineCap="Square" />
                    <Ellipse Width="{Binding SimpleCrosshairDotSize}"
                             Height="{Binding SimpleCrosshairDotSize}"
                             Fill="{Binding CrosshairBrush}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Grid>
            </Viewbox>

            <Viewbox Width="{Binding CrosshairSize}"
                     Height="{Binding CrosshairSize}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Opacity="{Binding CrosshairOpacity}"
                     Visibility="{Binding TechCrosshairVisibility}">
                <Grid Width="142" Height="142">
                    <Ellipse Width="46"
                             Height="46"
                             Stroke="{Binding CrosshairBrush}"
                             StrokeThickness="{Binding TechCrosshairThinStrokeThickness}"
                             Opacity="0.36"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    <Ellipse Width="12"
                             Height="12"
                             Stroke="{Binding CrosshairAlertBrush}"
                             StrokeThickness="{Binding TechCrosshairThinStrokeThickness}"
                             Opacity="0.88"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    <Line X1="71" Y1="18" X2="71" Y2="48"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding TechCrosshairStrokeThickness}"
                          Opacity="0.86" />
                    <Line X1="71" Y1="94" X2="71" Y2="124"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding TechCrosshairStrokeThickness}"
                          Opacity="0.86" />
                    <Line X1="18" Y1="71" X2="48" Y2="71"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding TechCrosshairStrokeThickness}"
                          Opacity="0.86" />
                    <Line X1="94" Y1="71" X2="124" Y2="71"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding TechCrosshairStrokeThickness}"
                          Opacity="0.86" />
                    <Path Data="M34,34 L46,34 M34,34 L34,46 M108,34 L96,34 M108,34 L108,46 M34,108 L46,108 M34,108 L34,96 M108,108 L96,108 M108,108 L108,96"
                          Stroke="{Binding CrosshairBrush}"
                          StrokeThickness="{Binding TechCrosshairCornerStrokeThickness}"
                          Opacity="0.52" />
                    <Path Data="M54,71 L66,71 M76,71 L88,71 M71,54 L71,66 M71,76 L71,88"
                          Stroke="{Binding CrosshairAlertBrush}"
                          StrokeThickness="{Binding TechCrosshairThinStrokeThickness}"
                          Opacity="0.78" />
                </Grid>
            </Viewbox>
        </Grid>

        <TextBlock Canvas.Left="0"
                   Canvas.Bottom="16"
                   Width="{Binding ActualWidth, ElementName=OverlayCanvas}"
                   Text="{Binding HotkeyToggleLabel}"
                   TextAlignment="Center"
                   Foreground="{Binding MutedBrush}"
                   FontSize="10" />
    </Canvas>
</Window>
