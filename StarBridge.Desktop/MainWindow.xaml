                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SyncOverlayDetailText"
                               Margin="0,6,0,0"
                               Text="正在同步服务器数据..."
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button x:Name="SyncOverlayRetryButton"
                        Grid.Column="1"
                        Content="重试"
                        Width="100"
                        Height="36"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="Collapsed"
                        Style="{StaticResource PrimaryButton}"
                        Click="SyncOverlayRetryButton_Click" />
            </Grid>
        </Border>

        <Border x:Name="UpdateProgressOverlay"
                Grid.RowSpan="2"
                Panel.ZIndex="140"
                Visibility="Collapsed"
                Background="#D9040910">
            <Grid>
                <Rectangle Fill="{StaticResource GeometricBackgroundBrush}"
                           Opacity="0.75"
                           IsHitTestVisible="False" />
                <Border Width="760"
                        Padding="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#F006101A"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="UpdateOverlayTitleText"
                                       Text="发现新版本"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="UpdateOverlayVersionText"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                            <TextBlock x:Name="UpdateOverlayModeText"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,22,0,0"
                                Padding="16"
                                MinHeight="110"
                                Background="{StaticResource FieldBackBrush}"
                                BorderBrush="{StaticResource AccentDimBrush}"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          MaxHeight="180">
                                <TextBlock x:Name="UpdateOverlayNotesText"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="2"
                              Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="72" />
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="UpdateOverlayProgressBar"
                                         Height="14"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0" />
                            <TextBlock x:Name="UpdateOverlayProgressText"
                                       Grid.Column="1"
                                       Text="0%"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold" />
                        </Grid>

                        <TextBlock x:Name="UpdateOverlayStatusText"
                                   Grid.Row="3"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />

                        <Grid Grid.Row="4"
                              Margin="0,26,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="更新期间应用会锁定操作。下载完成后可能自动关闭并重启，请不要手动结束更新进程。"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap" />
                            <Button x:Name="UpdateOverlayCancelButton"
                                    Grid.Column="1"
                                    Content="稍后"
                                    Height="40"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="UpdateOverlayCancelButton_Click" />
                            <Button x:Name="UpdateOverlayPrimaryButton"
                                    Grid.Column="2"
                                    Content="立即更新"
                                    Height="40"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="UpdateOverlayPrimaryButton_Click" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        </Grid>
    </Border>
</Window>

