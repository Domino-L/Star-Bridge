                                                    BorderThickness="1">
                                                <Grid>
                                                    <TextBlock x:Name="FleetShipInventoryEmptyText"
                                                               Text="暂无已上传舰船。玩家需要在个人页面通过官网机库读取器导入舰船。"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <ItemsControl x:Name="FleetShipInventoryList"
                                                                      Margin="10">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Style="{StaticResource SquadBannerPanel}"
                                                                            MinHeight="72"
                                                                            Margin="0,0,0,8">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="90" />
                                                                                <ColumnDefinition Width="260" />
                                                                                <ColumnDefinition Width="180" />
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="160" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding Number}"
                                                                                       Foreground="{StaticResource AccentBrush}"
                                                                                       FontWeight="SemiBold"
                                                                                       VerticalAlignment="Center" />
                                                                            <StackPanel Grid.Column="1"
                                                                                        VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding ShipName}"
                                                                                           Foreground="{StaticResource PrimaryTextBrush}"
                                                                                           FontWeight="SemiBold"
                                                                                           TextTrimming="CharacterEllipsis" />
                                                                                <TextBlock Text="官网机库已验证"
                                                                                           Style="{StaticResource HudCaptionText}"
                                                                                           Margin="0,4,0,0" />
