                                                                                       VerticalAlignment="Center" />
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </TabItem>
                                <TabItem x:Name="ManageFleetDisbandTab" Header="解散">
                                    <Border Style="{StaticResource HudPanel}"
                                            Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
