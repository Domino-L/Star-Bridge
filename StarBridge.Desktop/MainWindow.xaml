                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                                <RowDefinition Height="44" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Button x:Name="CreateSquadButton"
                                    Content="创建小队"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="CreateSquad_Click" />
                            <Button Grid.Row="1"
                                    x:Name="JoinSquadButton"
                                    Content="加入小队"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,10,0,0"
                                    IsEnabled="False"
                                    Click="JoinSquad_Click" />
                            <Button Grid.Row="2"
                                    x:Name="LeaveSquadButton"
                                    Content="离开小队"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,10,0,0"
                                    Visibility="Collapsed"
                                    Click="LeaveSquad_Click" />
                            <TextBlock Grid.Row="3"
                                       x:Name="JoinSquadHintText"
                                       Text="请选择一个小队"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <Grid Grid.Row="4"
                                  Margin="0,8,0,0">
                                <ListBox x:Name="SquadSelectionList"
                                         Background="{StaticResource FieldBackBrush}"
                                         BorderBrush="{StaticResource AccentDimBrush}"
                                         Foreground="{StaticResource PrimaryTextBrush}"
                                         SelectionChanged="SquadSelectionList_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10"
                                                    Margin="0,0,0,8"
                                                    BorderBrush="{StaticResource AccentDimBrush}"
                                                    BorderThickness="1"
                                                    Background="{StaticResource PanelBackBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="34"
                                                            Height="34"
                                                            BorderBrush="{StaticResource AccentBrush}"
                                                            BorderThickness="1"
                                                            Background="{StaticResource FieldBackBrush}">
                                                        <Grid>
                                                            <Image Source="{Binding EmblemPath, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill" />
                                                            <TextBlock Text="{Binding Icon}"
                                                                       Foreground="{StaticResource AccentBrush}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EmblemPath}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding EmblemPath}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding SummaryLine}"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel x:Name="NoSquadsPanel"
                                            VerticalAlignment="Center"
                                            Margin="12">
                                    <TextBlock Text="没有小队？"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="成为小队指挥官"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,18" />
                                    <Button Content="创建小队"
                                            Style="{StaticResource PrimaryButton}"
                                            Height="42"
                                            Click="CreateSquad_Click" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Style="{StaticResource HudPanel}"
                            Padding="24"
                            Margin="14,0,0,0">
                        <Grid>
                            <Grid x:Name="MySquadEmptyDetailPanel">
                                <TextBlock Text="未选择小队"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid x:Name="MySquadDetailPanel"
                                  Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="360" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="172"
                                        Height="172"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource FieldBackBrush}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="MySquadEmblem_MouseLeftButtonUp">
                                    <Grid Width="172" Height="172">
                                        <Image x:Name="MySquadEmblemImage"
                                               Stretch="UniformToFill" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="MySquadIconText"
                                                       Text="?"
                                                       FontSize="44"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock x:Name="MySquadEmblemHintText"
                                                       Text="Click to change"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="20,0,24,0"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="MySquadNameText"
                                               Text="No Squad"
                                               FontSize="28"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock x:Name="MySquadCommanderText"
                                               Text="Commander / Unassigned"
                                               Style="{StaticResource HudCaptionText}"
                                               Margin="0,8,0,0" />
                                    <TextBlock x:Name="MySquadMemberCountText"
                                               Text="0/0 Online"
                                               Style="{StaticResource HudCaptionText}"
                                               Margin="0,8,0,0" />
                                    <TextBlock x:Name="MySquadTypeText"
                                               Text="Type / Assault"
                                               Style="{StaticResource HudCaptionText}"
                                               Margin="0,8,0,0" />
                                </StackPanel>

                                <Border Grid.Column="2"
                                        BorderBrush="{StaticResource AccentDimBrush}"
                                        BorderThickness="1"
                                        Background="{StaticResource FieldBackBrush}"
                                        Padding="18">
                                    <TextBox x:Name="MySquadDescriptionBox"
                                             Text="No squad briefing yet."
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             TextChanged="MySquadDescriptionBox_TextChanged" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <ListView Grid.Row="1"
                              Grid.Column="1"
                              x:Name="MySquadMembersList"
                              Margin="14,14,0,0"
                              Background="{StaticResource FieldBackBrush}"
                              Foreground="{StaticResource PrimaryTextBrush}"
                              BorderBrush="{StaticResource AccentDimBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn x:Name="MySquadAvatarColumn" Header="Avatar" Width="86">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="38"
                                                    Height="38"
                                                    Background="{StaticResource FieldBackBrush}"
                                                    BorderBrush="{StaticResource AccentDimBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Image Source="{Binding AvatarPath, Converter={StaticResource ImagePathConverter}}"
                                                           Stretch="UniformToFill" />
                                                    <TextBlock Text="{Binding Avatar}"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AvatarPath}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AvatarPath}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="MySquadRoleColumn" Header="Role" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Role}" Foreground="{Binding NameBrush}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="MySquadCallsignColumn" Header="Callsign" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Callsign}" Foreground="{Binding NameBrush}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="MySquadGameIdColumn" Header="Game ID" Width="190">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding GameId}" Foreground="{Binding NameBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="MySquadOnlineColumn" Header="Online" DisplayMemberBinding="{Binding OnlineStatus}" Width="130" />
                                <GridViewColumn x:Name="MySquadShipColumn" Header="Ship Status" DisplayMemberBinding="{Binding ShipStatus}" Width="260" />
                                <GridViewColumn x:Name="MySquadLocationColumn" Header="Location" DisplayMemberBinding="{Binding Location}" Width="260" />
                                <GridViewColumn x:Name="MySquadActionColumn" Header="Action" Width="110">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="移除"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="28"
                                                    Padding="10,0"
                                                    Visibility="{Binding RemoveButtonVisibility}"
                                                    Click="RemoveSquadMember_Click" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border x:Name="SquadRequiresFleetPanel"
                            Grid.RowSpan="2"
                            Grid.ColumnSpan="2"
                            Panel.ZIndex="20"
                            Background="{StaticResource PageBackgroundBrush}"
                            BorderBrush="{StaticResource AccentDimBrush}"
                            BorderThickness="1"
                            Padding="28">
                        <StackPanel Width="560"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="SquadRequiresFleetTitleText"
                                       Text="尚未加入舰队"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="SquadRequiresFleetHintText"
                                       Text="需要先加入或创建舰队，才可以加入或创建小队。"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="15"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,28" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        x:Name="SquadFindFleetButton"
                                        Content="寻找舰队"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="44"
                                        Margin="0,0,8,0"
                                        Click="FleetFindButton_Click" />
                                <Button Grid.Column="1"
                                        x:Name="SquadCreateFleetButton"
                                        Content="创建舰队"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="44"
                                        Margin="8,0,0,0"
                                        Click="FleetCreateButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="CreateSquadPanel"
                            Grid.RowSpan="2"
                            Grid.ColumnSpan="2"
                            Panel.ZIndex="30"
                            Visibility="Collapsed"
                            Background="#CC02070D">
                        <Border Width="560"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Style="{StaticResource HudPanel}"
                                Padding="28">
                            <StackPanel>
                                <TextBlock Text="创建小队"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock x:Name="CreateSquadValidationText"
                                           Text=""
                                           Foreground="#FFFF5C5C"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="小队名称"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,18,0,6" />
                                <TextBox x:Name="CreateSquadNameBox"
                                         MaxLength="24" />
                                <TextBlock Text="小队类型"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,14,0,6" />
                                <ComboBox x:Name="CreateSquadTypeBox"
                                          SelectionChanged="CreateSquadTypeBox_SelectionChanged"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="突击" />
                                    <ComboBoxItem Content="支援" />
                                    <ComboBoxItem Content="侦察" />
                                    <ComboBoxItem Content="护航" />
                                    <ComboBoxItem Content="防空" />
                                    <ComboBoxItem Content="地面FPS" />
                                    <ComboBoxItem Content="地面支援" />
                                    <ComboBoxItem Content="后勤" />
                                    <ComboBoxItem Content="医疗" />
                                    <ComboBoxItem Content="采矿" />
                                    <ComboBoxItem Content="贸易" />
                                    <ComboBoxItem Content="自定义" />
                                </ComboBox>
                                <TextBox x:Name="CreateSquadCustomTypeBox"
                                         MaxLength="5"
                                         Visibility="Collapsed"
                                         Margin="0,8,0,0" />
                                <TextBlock Text="简述"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,14,0,6" />
                                <TextBox x:Name="CreateSquadDescriptionBox"
                                         Height="110"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Text="No squad briefing yet." />
                                <Grid Margin="0,22,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="取消"
                                            Style="{StaticResource SecondaryButton}"
                                            Height="42"
                                            Margin="0,0,8,0"
                                            Click="CreateSquadCancel_Click" />
                                    <Button Grid.Column="1"
                                            Content="创建"
                                            Style="{StaticResource PrimaryButton}"
                                            Height="42"
                                            Margin="8,0,0,0"
                                            Click="CreateSquadConfirm_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="OverlayEditTab" Header="Overlay Edit">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               x:Name="OverlayEditHintText"
                               Text="Drag panels to move. Drag the lower-right handle to resize. Saved layout is applied to fullscreen Overlay."
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            Style="{StaticResource HudPanel}"
                            Padding="14"
                            Margin="0,0,12,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock x:Name="OverlayPresetLabel"
                                           Text="PRESET"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,0,0,8" />
                                <ComboBox x:Name="OverlayPresetBox"
                                          Height="32"
                                          Margin="0,0,0,14"
                                          SelectionChanged="OverlayPresetBox_SelectionChanged">
                                    <ComboBoxItem Content="战斗" Tag="combat" />
                                    <ComboBoxItem Content="精简" Tag="compact" />
                                    <ComboBoxItem Content="指挥" Tag="command" />
                                    <ComboBoxItem Content="自定义" Tag="custom" />
                                </ComboBox>
                                <TextBlock x:Name="OverlayHotkeyLabel"
                                           Text="OVERLAY 热键"
                                           Style="{StaticResource HudCaptionText}"
                                           Margin="0,0,0,8" />
                                <TextBox x:Name="OverlayHotkeyBox"
                                         IsReadOnly="True"
                                         Height="32"
                                         VerticalContentAlignment="Center"
                                         Text="F8"
                                         ToolTip="点击后按下自定义 Overlay 热键"
                                         GotKeyboardFocus="OverlayHotkeyBox_GotKeyboardFocus"
                                         PreviewKeyDown="OverlayHotkeyBox_PreviewKeyDown" />
                                <TextBlock x:Name="HotkeyLimitHintText"
                                           Text="由于游戏限制，星际公民在前台时无法使用热键开关 Overlay。"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,14" />
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            x:Name="SaveLayoutButton"
                                            Margin="0,0,6,0"
                                            Style="{StaticResource PrimaryButton}"
                                            Content="Save Layout"
                                            Click="SaveOverlayLayout_Click" />
                                    <Button Grid.Column="1"
                                            x:Name="ResetLayoutButton"
                                            Margin="6,0,0,0"
                                            Style="{StaticResource SecondaryButton}"
                                            Content="Reset"
                                            Click="ResetOverlayLayout_Click" />
                                </Grid>

                                <TextBlock x:Name="OverlayOptionsLabel" Text="OVERLAY OPTIONS" Style="{StaticResource HudCaptionText}" Margin="0,0,0,8" />
                                <CheckBox x:Name="ShowNoticePanelCheck"
                                          Content="Show fleet notice"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="ShowSquadsPanelCheck"
                                          Content="Show squad list"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="ShowMissionPanelCheck"
                                          Content="Show task panel"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="ShowMembersPanelCheck"
                                          Content="Show member status"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="HideMissionWhenIdleCheck"
                                          Content="No task: hide mission overlay"
                                          Margin="0,14,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="HideOfflineMembersCheck"
                                          Content="Hide offline squad members"
                                          Margin="0,8,0,0"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <CheckBox x:Name="HideSquadIconsCheck"
                                          Content="Left panel: hide squad icons"
                                          Margin="0,8,0,18"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />

                                <TextBlock x:Name="MemberNameDisplayLabel" Text="MEMBER NAME DISPLAY" Style="{StaticResource HudCaptionText}" Margin="0,0,0,8" />
                                <RadioButton x:Name="ShowCallsignAndNameRadio"
                                             Content="Show callsign and game name"
                                             GroupName="OverlayMemberName"
                                             Checked="OverlaySetting_Changed" />
                                <RadioButton x:Name="ShowCallsignOnlyRadio"
                                             Content="Only callsign"
                                             GroupName="OverlayMemberName"
                                             Margin="0,8,0,0"
                                             Checked="OverlaySetting_Changed" />
                                <RadioButton x:Name="ShowGameNameOnlyRadio"
                                             Content="Only game name"
                                             GroupName="OverlayMemberName"
                                             Margin="0,8,0,18"
                                             Checked="OverlaySetting_Changed" />

                                <TextBlock x:Name="OverlayThemeLabel" Text="APPEARANCE" Style="{StaticResource HudCaptionText}" Margin="0,0,0,8" />
                                <ComboBox x:Name="OverlayThemeBox"
                                          Height="32"
                                          Margin="0,0,0,8"
                                          SelectionChanged="OverlayThemeBox_SelectionChanged">
                                    <ComboBoxItem Content="默认" />
                                    <ComboBoxItem Content="铁砧" />
                                    <ComboBoxItem Content="德雷克" />
                                    <ComboBoxItem Content="南船座" />
                                    <ComboBoxItem Content="武藏" />
                                    <ComboBoxItem Content="未来" />
                                    <ComboBoxItem Content="十字军" />
                                    <ComboBoxItem Content="圣盾" />
                                    <ComboBoxItem Content="RSI" />
                                    <ComboBoxItem Content="起源" />
                                    <ComboBoxItem Content="奥波亚" />
                                    <ComboBoxItem Content="埃斯佩里亚" />
                                    <ComboBoxItem Content="盖塔克" />
                                </ComboBox>
                                <CheckBox x:Name="AutoThemeByShipCheck"
                                          Content="自动切换至当前飞船厂商风格"
                                          Margin="0,0,0,18"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />

                                <TextBlock x:Name="CrosshairLabel" Text="虚拟准星" Style="{StaticResource HudCaptionText}" Margin="0,0,0,8" />
                                <CheckBox x:Name="ShowCrosshairCheck"
                                          Content="显示虚拟准星"
                                          Margin="0,0,0,8"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="SimpleCrosshairRadio"
                                                 Content="简洁"
                                                 GroupName="OverlayCrosshair"
                                                 Checked="OverlaySetting_Changed" />
                                    <RadioButton x:Name="TechCrosshairRadio"
                                                 Grid.Column="1"
                                                 Content="科技"
                                                 GroupName="OverlayCrosshair"
                                                 Margin="12,0,0,0"
                                                 Checked="OverlaySetting_Changed" />
                                </Grid>
                                <CheckBox x:Name="CrosshairThemeColorCheck"
                                          Content="跟随当前风格颜色"
                                          Margin="0,0,0,10"
                                          Checked="OverlaySetting_Changed"
                                          Unchecked="OverlaySetting_Changed" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CrosshairSizeLabel"
                                               Text="大小"
                                               Style="{StaticResource HudCaptionText}" />
                                    <TextBlock x:Name="CrosshairSizeValueText"
                                               Grid.Column="1"
                                               Text="96px"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>
                                <Slider x:Name="CrosshairSizeSlider"
                                        Minimum="48"
                                        Maximum="240"
                                        TickFrequency="4"
                                        ValueChanged="CrosshairSlider_ValueChanged" />
                                <Grid Margin="0,10,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CrosshairThicknessLabel"
                                               Text="粗细"
                                               Style="{StaticResource HudCaptionText}" />
                                    <TextBlock x:Name="CrosshairThicknessValueText"
                                               Grid.Column="1"
                                               Text="2px"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>
                                <Slider x:Name="CrosshairThicknessSlider"
                                        Minimum="1"
                                        Maximum="8"
                                        TickFrequency="0.25"
                                        ValueChanged="CrosshairSlider_ValueChanged" />
                                <Grid Margin="0,10,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CrosshairOpacityLabel"
                                               Text="准星透明度"
                                               Style="{StaticResource HudCaptionText}" />
                                    <TextBlock x:Name="CrosshairOpacityValueText"
                                               Grid.Column="1"
                                               Text="85%"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>
                                <Slider x:Name="CrosshairOpacitySlider"
                                        Minimum="20"
                                        Maximum="100"
                                        TickFrequency="5"
