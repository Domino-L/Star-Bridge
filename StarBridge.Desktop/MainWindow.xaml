                                                                                           Margin="0,6,0,0"
                                                                                           TextTrimming="CharacterEllipsis">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding ShowRoleEditor}" Value="True">
                                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
